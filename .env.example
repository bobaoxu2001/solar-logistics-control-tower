# Copy to .env and adjust. Never commit .env.
#
# PostgreSQL (primary target — start with `docker compose up -d`):
# DATABASE_URL=postgresql+psycopg2://sunlog:sunlog_dev_password@localhost:5432/sunlog
#
# SQLite (fallback — no server required; default when DATABASE_URL is unset):
# DATABASE_URL=sqlite:///data/processed/sunlog.db
DATABASE_URL=sqlite:///data/processed/sunlog.db

# Postgres container credentials (used by docker-compose.yml only)
POSTGRES_USER=sunlog
POSTGRES_PASSWORD=sunlog_dev_password
POSTGRES_DB=sunlog
